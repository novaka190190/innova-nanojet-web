      color: rgba(255,255,255,0.65);
    }
    .hero__scroll {
      position: absolute;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      color: white;
      opacity: 0.6;
      animation: bounce 2s infinite;
      z-index: 1;
    }
    @keyframes bounce {
      0%, 100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(8px); }
    }

    /* HOW IT WORKS */
    .how-it-works {
      padding: var(--section-pad);
      background: var(--color-gray-light);
    }
    .section-header {
      text-align: center;
      margin-bottom: 60px;
    }
    .section-header .section-subtitle {
      margin: 0 auto;
    }
    .how-it-works__steps {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      gap: 0;
      margin-bottom: 80px;
      flex-wrap: wrap;
    }
    .step {
      background: white;
      border-radius: var(--radius);
      padding: 36px 28px;
      text-align: center;
      max-width: 280px;
      box-shadow: var(--shadow);
      position: relative;
    }
    .step__icon {
      width: 80px;
      height: 80px;
      margin: 0 auto 20px;
    }
    .step__num {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      width: 28px;
      height: 28px;
      background: var(--color-blue);
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      font-weight: 700;
    }
    .step h3 {
      font-size: 1.1rem;
      margin-bottom: 12px;
      color: var(--color-dark);
    }
    .step p {
      font-size: 0.9rem;
      color: var(--color-gray);
      line-height: 1.6;
    }
    .step__arrow {
      font-size: 2rem;
      color: var(--color-blue);
      margin: 60px 16px 0;
      font-weight: 300;
      align-self: flex-start;
    }
    .how-it-works__visual {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    .how-it-works__image img {
      border-radius: var(--radius);
      width: 100%;
    }
    .diagram-caption {
      margin-top: 12px;
      font-size: 0.82rem;
      color: var(--color-gray);
      font-style: italic;
      line-height: 1.5;
    }
    .how-it-works__text h3 {
      font-size: 1.5rem;
      color: var(--color-dark);
      margin-bottom: 16px;
    }
    .how-it-works__text p {
      color: var(--color-gray-dark);
      margin-bottom: 16px;
      line-height: 1.7;
    }
    .check-list {
      list-style: none;
      margin-top: 24px;
    }
    .check-list li {
      padding: 8px 0;
      padding-left: 28px;
      position: relative;
      color: var(--color-gray-dark);
      font-weight: 500;
      font-size: 0.95rem;
    }
    .check-list li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--color-blue);
      font-weight: 700;
    }

    /* COMPARISON */
    .comparison {
      padding: var(--section-pad);
      background: white;
    }
    .comparison-table-wrap {
      overflow-x: auto;
      margin-bottom: 32px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }
    .comparison-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    .comparison-table th,
    .comparison-table td {
      padding: 14px 16px;
      text-align: left;
      border-bottom: 1px solid #e5e7eb;
    }
    .comparison-table thead th {
      background: var(--color-dark);
      color: white;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .comparison-table thead th:first-child {
      border-radius: var(--radius) 0 0 0;
    }
    .comparison-table thead th:last-child {
      border-radius: 0 var(--radius) 0 0;
    }
    .comparison-table tbody tr:last-child td {
      border-bottom: none;
    }
    .comparison-table tbody tr:hover {
      background: #f9fafb;
    }
    .highlight-col {
      background: rgba(33, 150, 243, 0.06);
    }
    .highlight-col strong {
      color: var(--color-blue-dark);
    }
    .comparison-table th.highlight-col {
      background: var(--color-blue);
    }
    .comparison-note {
      background: #f0f9ff;
      border-left: 4px solid var(--color-blue);
      padding: 20px 24px;
      border-radius: 0 var(--radius) var(--radius) 0;
      color: var(--color-gray-dark);
      font-size: 0.95rem;
      line-height: 1.7;
    }
    .comparison-note strong {
      color: var(--color-dark);
    }

    /* FOR WHOM */
    .for-whom {
      padding: var(--section-pad);
      background: var(--color-gray-light);
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      margin-bottom: 80px;
    }
    .cards-grid--5 {
      grid-template-columns: repeat(5, 1fr);
    }
    .card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      padding: 32px 20px;
      transition: all 0.3s ease;
    }
    .card:hover {
      border-color: var(--color-blue);
      box-shadow: var(--shadow);
      transform: translateY(-4px);
    }
    .card__icon {
      font-size: 2.5rem;
      margin-bottom: 16px;
    }
    .card h3 {
      font-size: 1rem;
      margin-bottom: 10px;
      color: var(--color-dark);
    }
    .card p {
      font-size: 0.875rem;
      color: var(--color-gray);
      line-height: 1.6;
    }
    .product-showcase {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
      background: white;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .product-showcase__image img {
      width: 100%;
      height: 400px;
      object-fit: cover;
    }
    .product-showcase__content {
      padding: 40px 40px 40px 0;
    }
    .product-showcase__content h3 {
      font-size: 1.6rem;
      color: var(--color-dark);
      margin-bottom: 16px;
    }
    .product-showcase__content p {
      color: var(--color-gray-dark);
      margin-bottom: 16px;
      line-height: 1.7;
    }

    /* FEATURES */
    .features {
      padding: var(--section-pad);
      background: var(--color-dark);
    }
    .features__inner {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 80px;
      align-items: center;
    }
    .features__image img {
      border-radius: var(--radius);
      width: 100%;
      object-fit: cover;
    }
    .features .section-title {
      color: white;
    }
    .features__list {
      list-style: none;
      margin-top: 32px;
    }
    .features__list li {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      padding: 16px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .features__list li:last-child {
      border-bottom: none;
    }
    .check-icon {
      width: 24px;
      height: 24px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .features__list li div strong {
      display: block;
      color: white;
      font-weight: 600;
      margin-bottom: 2px;
    }
    .features__list li div span {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
    }

    /* PRICE */
    .price-section {
      padding: 48px 24px;
      background: var(--color-dark-mid);
    }
    .price-box {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      flex-wrap: wrap;
      background: rgba(33,150,243,0.1);
      border: 1px solid rgba(33,150,243,0.3);
      border-radius: var(--radius);
      padding: 32px 40px;
    }
    .price-box__content h3 {
      font-size: 1.4rem;
      color: white;
      margin-bottom: 8px;
    }
    .price-box__content h3 strong {
      color: var(--color-blue-light);
      font-size: 1.6rem;
    }
    .price-box__content h3 span {
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      font-weight: 400;
    }
    .price-box__content p {
      color: rgba(255,255,255,0.7);
      font-size: 0.95rem;
    }

    /* PRESS */
    .press {
      padding: var(--section-pad);
      background: var(--color-gray-light);
    }
    .press__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .press__card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      padding: 28px;
      display: block;
      transition: all 0.3s;
      text-decoration: none;
    }
    .press__card:hover {
      border-color: var(--color-blue);
      box-shadow: var(--shadow);
      transform: translateY(-3px);
    }
    .press__media {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-blue);
      background: rgba(33,150,243,0.1);
      display: inline-block;
      padding: 4px 12px;
      border-radius: 50px;
      margin-bottom: 16px;
    }
    .press__card h3 {
      font-size: 1rem;
      color: var(--color-dark);
      margin-bottom: 10px;
      line-height: 1.4;
    }
    .press__card p {
      font-size: 0.875rem;
      color: var(--color-gray);
      line-height: 1.6;
      margin-bottom: 16px;
    }
    .press__link {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-blue);
    }

    /* FIRST CTA */
    .first-cta {
      padding: 60px 24px;
      background: var(--color-blue);
    }
    .first-cta__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      flex-wrap: wrap;
    }
    .first-cta__inner h2 {
      font-size: clamp(1.4rem, 2.5vw, 2rem);
      color: white;
      margin-bottom: 8px;
    }
    .first-cta__inner p {
      color: rgba(255,255,255,0.85);
      font-size: 1rem;
    }
    .first-cta .btn-primary {
      background: white;
      color: var(--color-blue);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .first-cta .btn-primary:hover {
      background: rgba(255,255,255,0.9);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }

    /* FAQ */
    .faq {
      padding: var(--section-pad);
      background: white;
    }
    .faq__list {
      max-width: 800px;
      margin: 0 auto;
    }
    .faq__item {
      background: var(--color-gray-light);
      border-radius: var(--radius);
      margin-bottom: 12px;
      border: 1px solid #e5e7eb;
      overflow: hidden;
    }
    .faq__item summary {
      padding: 20px 24px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--color-dark);
      list-style: none;
      transition: background 0.2s;
      font-size: 1rem;
    }
    .faq__item summary::-webkit-details-marker { display: none; }
    .faq__item summary::after {
      content: '+';
      font-size: 1.5rem;
      font-weight: 300;
      color: var(--color-blue);
      transition: transform 0.3s;
      flex-shrink: 0;
      margin-left: 16px;
    }
    .faq__item[open] summary::after {
      transform: rotate(45deg);
    }
    .faq__item[open] summary {
      background: rgba(33,150,243,0.06);
    }
    .faq__answer {
      border-top: 1px solid #e5e7eb;
      padding: 20px 24px 24px;
    }
    .faq__answer p {
      color: var(--color-gray-dark);
      font-size: 0.95rem;
      line-height: 1.75;
      margin: 0;
    }

    /* CONTACT */
    .contact {
      padding: var(--section-pad);
      background: var(--color-dark-mid);
    }
    .contact__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: start;
    }
    .contact__direct {
      margin-bottom: 32px;
    }
    .contact__email {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--color-blue-light);
      font-size: 1.1rem;
      font-weight: 600;
      margin-top: 8px;
      text-decoration: underline;
    }
    .contact__image {
      border-radius: var(--radius);
      width: 100%;
      max-height: 260px;
      object-fit: cover;
      margin-top: 32px;
    }
    .contact__form-wrap {
      background: white;
      border-radius: 20px;
      padding: 40px;
    }
    .contact__form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-group label {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-gray-dark);
    }
    .form-group input,
    .form-group textarea {
      padding: 12px 16px;
      border: 1.5px solid #e5e7eb;
      border-radius: 10px;
      font-family: var(--font);
      font-size: 0.95rem;
      color: var(--color-text);
      transition: border-color 0.2s;
      outline: none;
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--color-blue);
    }
    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }
    .form-success {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-radius: 10px;
      padding: 16px;
      color: #166534;
      font-weight: 500;
    }
    .form-note {
      text-align: center;
      font-size: 0.8rem;
      color: var(--color-gray);
      margin-top: -8px;
    }

    /* FOOTER */
    .footer {
      background: var(--color-dark);
      color: rgba(255,255,255,0.7);
      padding: 60px 0 32px;
    }
    .footer__inner {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 40px;
      margin-bottom: 32px;
    }
    .footer__brand img {
      filter: brightness(0) invert(1);
      margin-bottom: 16px;
    }
    .footer__brand p {
      font-size: 0.875rem;
      margin-bottom: 6px;
      line-height: 1.6;
    }
    .footer__email {
      display: block;
      color: var(--color-blue-light);
      font-size: 0.875rem;
      margin-bottom: 4px;
    }
    .footer__links h4 {
      color: white;
      font-size: 0.875rem;
      margin-bottom: 14px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .footer__links ul {
      list-style: none;
    }
    .footer__links li {
      margin-bottom: 8px;
    }
    .footer__links a {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.55);
      transition: color 0.2s;
    }
    .footer__links a:hover {
      color: white;
    }

    /* BACK TO TOP */
    .back-to-top {
      position: fixed;
      bottom: 32px;
      right: 32px;
      width: 48px;
      height: 48px;
      background: var(--color-blue);
      color: white;
      border: none;
      border-radius: 50%;
      font-size: 1.2rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 16px rgba(33,150,243,0.4);
      opacity: 0;
      transform: translateY(16px);
      transition: all 0.3s ease;
      z-index: 999;
    }
    .back-to-top--visible {
      opacity: 1;
      transform: translateY(0);
    }
    .back-to-top:hover {
      background: var(--color-blue-dark);
      transform: translateY(-2px);
    }

    /* RESPONSIVE */
    @media (max-width: 1200px) {
      .cards-grid--5 { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 1024px) {
      .cards-grid { grid-template-columns: repeat(2, 1fr); }
      .how-it-works__visual { grid-template-columns: 1fr; }
      .features__inner { grid-template-columns: 1fr; }
      .features__image { display: none; }
      .press__grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 768px) {
      .nav__links {
        display: none;
        position: fixed;
        top: 60px;
        left: 0;
        right: 0;
        background: var(--color-dark);
        flex-direction: column;
        padding: 24px;
        gap: 16px;
      }
      .nav__links--open { display: flex; }
      .nav__toggle { display: flex; }
      .how-it-works__steps { flex-direction: column; align-items: center; }
      .step__arrow { transform: rotate(90deg); margin: 0 0 0 0; }
      .cards-grid { grid-template-columns: 1fr; }
      .cards-grid--5 { grid-template-columns: 1fr; }
      .product-showcase { grid-template-columns: 1fr; }
      .product-showcase__content { padding: 32px 24px; }
      .contact__inner { grid-template-columns: 1fr; }
      .footer__inner { grid-template-columns: 1fr; }
      .press__grid { grid-template-columns: 1fr; }
      .first-cta__inner { flex-direction: column; }
      .price-box { flex-direction: column; }
    }

    @media (max-width: 480px) {
      .hero__stats { gap: 24px; }
      .hero__actions { flex-direction: column; }
      .contact__form-wrap { padding: 24px; }
      .back-to-top { bottom: 20px; right: 20px; }
    }
  </style>
</BaseLayout>
