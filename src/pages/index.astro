---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://innova-nanojet.cz/#organization",
      "name": "Inovara Group s.r.o.",
      "url": "https://innova-nanojet.cz",
      "email": "info@inovaratrade.com",
      "sameAs": ["https://www.inovaratrade.com"],
      "description": "Oficiální distributor AirSancta CDa Pro pro střední a východní Evropu"
    },
    {
      "@type": "Product",
      "@id": "https://innova-nanojet.cz/#product",
      "name": "AirSancta CDa Pro",
      "description": "Čistička vzduchu bez filtrů s patentovanou NanoJet technologií. Čistí vzduch vodní nano-mlhou za 2–5 minut. Odstraní 99 % virů, bakterií a alergenů. Bez chemie, bez filtrů.",
      "brand": {
        "@type": "Brand",
        "name": "AirSancta"
      },
      "manufacturer": {
        "@type": "Organization",
        "name": "Innova NanoJet Technologies Ltd",
        "url": "https://www.innova-nanojet.co.uk"
      },
      "image": "https://innova-nanojet.cz/images/product-cda-pro.jpg",
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "price": "1359",
        "priceCurrency": "EUR",
        "seller": {
          "@type": "Organization",
          "name": "Inovara Group s.r.o."
        }
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://innova-nanojet.cz/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Jaký je rozdíl mezi čističkou vzduchu a zvlhčovačem?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Čistička odstraňuje nečistoty, zvlhčovač přidává vlhkost. CDa Pro díky principu vodní nano-mlhy dělá obojí — čistí vzduch a zároveň ho přirozeně zvlhčuje. V zimě při vytápění je to zásadní výhoda."
          }
        },
        {
          "@type": "Question",
          "name": "Pomůže CDa Pro proti cigaretovému kouři od sousedů?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ano. Nano-kapky fyzicky zachycují částice kouře a pachové molekuly a sráží je k zemi. CDa Pro je účinná i proti VOC (těkavým organickým látkám), které jsou hlavní složkou cigaretového kouře."
          }
        },
        {
          "@type": "Question",
          "name": "Kolik stojí výměna filtrů u běžné čističky vzduchu?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Běžné HEPA filtry stojí 500–2 000 Kč za kus a mění se každých 3–6 měsíců. Ročně to vyjde na 2 000–8 000 Kč. CDa Pro žádné filtry nemá — jediný provozní náklad je destilovaná voda."
          }
        },
        {
          "@type": "Question",
          "name": "Nepoškodí nano-mlha elektroniku, papíry nebo nábytek?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ne. Kapky jsou tak mikroskopické (5–10 µm), že se odpařují přímo ve vzduchu. Neusazují se na površích, nezvlhčují elektroniku ani dokumenty. To je zásadní rozdíl oproti klasickým zvlhčovačům."
          }
        },
        {
          "@type": "Question",
          "name": "Musím přístroj nechat běžet celý den?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Vůbec ne. Stačí CDa Pro pustit na 2–5 minut a vzduch je čistý až 6 hodin. Zapněte ji třeba když si odskočíte na záchod nebo na oběd — a vrátíte se do čisté místnosti."
          }
        },
        {
          "@type": "Question",
          "name": "Jak hlučný je přístroj?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hlučnost je do 80 dB, podobně jako vysavač. Klíčový rozdíl: CDa Pro stačí pustit na 2–5 minut, ne na celý den. Zapněte ji na chvíli, když opouštíte místnost, a vrátíte se do tiché, čisté místnosti."
          }
        },
        {
          "@type": "Question",
          "name": "Je CDa Pro ekologická?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Maximálně. Neprodukuje žádný odpad z filtrů, nepoužívá chemikálie. Jediným spotřebním materiálem je destilovaná voda."
          }
        },
        {
          "@type": "Question",
          "name": "Je CDa Pro bezpečná pro děti a domácí zvířata?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ano. Přístroj nepoužívá žádné chemikálie — pouze čistou vodu. Chemicky neutrální princip je bezpečný za přítomnosti celé rodiny."
          }
        },
        {
          "@type": "Question",
          "name": "Jakou vodu mám používat?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pouze destilovanou nebo demineralizovanou vodu. Nepoužívejte kohoutkovou vodu — mohlo by dojít k ucpání trysek."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  title="Čistička vzduchu bez filtrů | Čištění vzduchu vodou za 2 minuty | innova-nanojet.cz"
  description="AirSancta CDa Pro — inovativní čistička vzduchu bez filtrů a chemie. Čistí vzduch vodní nano-mlhou za 2–5 minut. Odstraní 99 % virů, bakterií a alergenů. Buďte mezi prvními v ČR."
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- NAVIGACE -->
  <nav class="nav" id="nav">
    <div class="nav__inner container">
      <a href="/" class="nav__logo">
        <img src="/images/airsancta-logo.png" alt="AirSancta logo" width="140" height="40" loading="eager" />
      </a>
      <ul class="nav__links">
        <li><a href="#jak-to-funguje">Jak to funguje</a></li>
        <li><a href="#srovnani">Srovnání</a></li>
        <li><a href="#pro-koho">Pro koho</a></li>
        <li><a href="#vlastnosti">Vlastnosti</a></li>
        <li><a href="#napsali-o-nas">Napsali o nás</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="#kontakt" class="btn btn-primary">Kontakt</a></li>
      </ul>
      <button class="nav__toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero__bg">
      <img src="/images/hero.jpg" alt="AirSancta CDa Pro čistička vzduchu bez filtrů v moderním interiéru" width="1920" height="1080" loading="eager" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content container">
      <div class="hero__badge">
        <img src="/images/ces-award.png" alt="CES Innovation Award" width="80" height="80" loading="eager" />
        <span>Ocenění CES Innovation Award</span>
      </div>
      <h1 class="hero__title">Čistička vzduchu bez filtrů —<br />vyčistí místnost za 2 minuty</h1>
      <p class="hero__subtitle">
        AirSancta CDa Pro je první čistička vzduchu v ČR, která používá pouze vodu.
        Žádné filtry, žádná chemie, žádný odpad.
        Těžce inovativní technologie, kterou si můžete vyzkoušet jako jedni z prvních.
      </p>
      <div class="hero__actions">
        <a href="#kontakt" class="btn btn-primary">Chci vyzkoušet jako první</a>
        <a href="#jak-to-funguje" class="btn btn-outline">Jak to funguje?</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <strong>2–5 min</strong>
          <span>Vyčistí vzduch v místnosti</span>
        </div>
        <div class="hero__stat">
          <strong>99 %</strong>
          <span>Odstranění nečistot</span>
        </div>
        <div class="hero__stat">
          <strong>0 Kč</strong>
          <span>Náklady na filtry ročně</span>
        </div>
      </div>
    </div>
    <a href="#jak-to-funguje" class="hero__scroll" aria-label="Scrollovat dolů">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </section>

  <!-- JAK TO FUNGUJE -->
  <section class="how-it-works" id="jak-to-funguje">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Technologie</span>
        <h2 class="section-title">Jak funguje čištění vzduchu vodní nano-mlhou?</h2>
        <p class="section-subtitle">
          Zatímco klasické čističky nasávají vzduch přes filtr a doufají, že zachytí co nejvíc,
          CDa Pro funguje úplně jinak. Aktivně vysílá do prostoru biliony nano-kapek vody,
          které loví nečistoty přímo ve vzduchu — a to za pouhé 2–5 minut.
        </p>
      </div>

      <div class="how-it-works__steps">
        <div class="step">
          <div class="step__icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="28" fill="rgba(33,150,243,0.12)"/>
              <path d="M32 20c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm0 4a8 8 0 110 16 8 8 0 010-16z" fill="#2196F3"/>
              <circle cx="20" cy="22" r="3" fill="#2196F3" opacity="0.6"/>
              <circle cx="44" cy="22" r="2" fill="#2196F3" opacity="0.4"/>
              <circle cx="44" cy="42" r="3" fill="#2196F3" opacity="0.6"/>
              <circle cx="20" cy="42" r="2" fill="#2196F3" opacity="0.4"/>
            </svg>
          </div>
          <div class="step__num">1</div>
          <h3>Biliony nano-kapek vody</h3>
          <p>Přístroj vytvoří biliony mikroskopických vodních kapek, které se rozletí do celé místnosti. Jsou tisíckrát menší než kapky z běžného zvlhčovače.</p>
        </div>
        <div class="step__arrow">→</div>
        <div class="step">
          <div class="step__icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="28" fill="rgba(33,150,243,0.12)"/>
              <path d="M24 28l8 8 8-8" stroke="#2196F3" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M20 36s4-8 12-8 12 8 12 8" stroke="#2196F3" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="32" cy="20" r="4" fill="#2196F3"/>
            </svg>
          </div>
          <div class="step__num">2</div>
          <h3>Zachycení a eliminace</h3>
          <p>Nano-kapky obalí viry, bakterie, alergeny i pachové molekuly přímo ve vzduchu. Funguje to i na částice menší než 300 nanometrů — tedy i na chřipku nebo koronavirus.</p>
        </div>
        <div class="step__arrow">→</div>
        <div class="step">
          <div class="step__icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="28" fill="rgba(33,150,243,0.12)"/>
              <path d="M32 18v28M22 36l10 10 10-10" stroke="#2196F3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M20 22h24" stroke="#2196F3" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
            </svg>
          </div>
          <div class="step__num">3</div>
          <h3>Čistý vzduch za minuty</h3>
          <p>Obalené nečistoty ztěžknou a klesnou k zemi. Vzduch je čistý za 2–5 minut a zůstává dezinfikovaný až 6 hodin. A kapky jsou tak jemné, že nezvlhčí elektroniku ani papíry.</p>
        </div>
      </div>

      <div class="how-it-works__visual">
        <div class="how-it-works__image">
          <img src="/images/nanojet-diagram.png" alt="Diagram technologie NanoJet — srovnání běžného spreje a nano-kapek" width="600" height="400" loading="lazy" />
          <p class="diagram-caption">
            Srovnání běžného spreje (vlevo) a technologie NanoJet (vpravo).
            NanoJet vytváří kapky tisíckrát menší, které se neusazují na površích,
            ale aktivně čistí vzduch v celé místnosti.
          </p>
        </div>
        <div class="how-it-works__text">
          <h3>Vojenský původ. Civilní nasazení od 2024.</h3>
          <p>
            Tato technologie byla původně vyvíjena pro vojenský průmysl v oblasti biologické
            a chemické obrany. Na civilní trh vstoupila v roce 2024 a je chráněna patenty
            (US 63/531 044, PCT/US24/25231).
          </p>
          <p>
            Průmyslová tryska rozprašuje vodu na kapky o velikosti 5–10 mikronů —
            tisíckrát menší než kapky z klasického zvlhčovače.
            Tyto kapky mají mimořádně velký povrch, díky čemuž jsou velmi účinné
            při zachycování aerosolových částic, virů a bakterií.
          </p>
          <ul class="check-list">
            <li>Ověřeno nezávislými laboratořemi (LMS Technologies USA, NHS UK)</li>
            <li>Reference: Nemocnice Strakonice, NHS Health Innovation NWC</li>
            <li>Patentovaná technologie — certifikace CE, UKCA</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SROVNÁNÍ -->
  <section class="comparison" id="srovnani">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Srovnání</span>
        <h2 class="section-title">Proč jsou klasické čističky s HEPA filtrem nedostatečné?</h2>
        <p class="section-subtitle">
          HEPA filtry jsou prověřená technologie — ale mají zásadní limity, o kterých výrobci neradi mluví.
        </p>
      </div>

      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th></th>
              <th class="highlight-col">CDa Pro<br/><small>(vodní nano-mlha)</small></th>
              <th>HEPA čistička</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Princip</td>
              <td class="highlight-col"><strong>Aktivně vysílá nano-kapky do prostoru</strong></td>
              <td>Pasivně nasává vzduch přes filtr</td>
            </tr>
            <tr>
              <td>Rychlost čištění</td>
              <td class="highlight-col"><strong>2–5 minut</strong></td>
              <td>Hodiny nepřetržitého provozu</td>
            </tr>
            <tr>
              <td>Zachycení virů pod 300 nm</td>
              <td class="highlight-col"><strong>Ano</strong> (od 10 nm)</td>
              <td>Ne — HEPA zachycuje od 300 nm výš</td>
            </tr>
            <tr>
              <td>Riziko rozšiřování virů</td>
              <td class="highlight-col"><strong>Ne</strong> — sráží je dolů</td>
              <td>Ano — ventilátor je může rozhánět po místnosti</td>
            </tr>
            <tr>
              <td>Náklady na filtry ročně</td>
              <td class="highlight-col"><strong>0 Kč</strong></td>
              <td>2 000–8 000 Kč (výměna 2–4× ročně)</td>
            </tr>
            <tr>
              <td>Odpad z filtrů</td>
              <td class="highlight-col"><strong>Žádný</strong></td>
              <td>2–4 filtry ročně (potenciálně nebezpečný odpad)</td>
            </tr>
            <tr>
              <td>Zvlhčování vzduchu</td>
              <td class="highlight-col"><strong>Ano</strong>, přirozeně</td>
              <td>Ne</td>
            </tr>
            <tr>
              <td>Odstranění pachů a VOC</td>
              <td class="highlight-col"><strong>Ano</strong></td>
              <td>Částečně (jen s uhlíkovým filtrem)</td>
            </tr>
            <tr>
              <td>Bezpečnost pro elektroniku</td>
              <td class="highlight-col"><strong>Ano</strong> — kapky se odpařují ve vzduchu</td>
              <td>Ano</td>
            </tr>
            <tr>
              <td>Doba potřebného provozu</td>
              <td class="highlight-col"><strong>2–5 min</strong>, účinek trvá až 6 hodin</td>
              <td>Celý den pro trvalý efekt</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="comparison-note">
        <strong>Nejdůležitější rozdíl?</strong> I ty nejjemnější HEPA filtry nedokáží zachytit běžné respirační viry,
        jako je chřipka nebo Covid-19. Jejich ventilátor navíc může virové částice rozšiřovat po místnosti.
        CDa Pro funguje opačně — nano-kapky viry obalí a srazí k zemi.
      </div>
    </div>
  </section>

  <!-- PRO KOHO -->
  <section class="for-whom" id="pro-koho">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Využití</span>
        <h2 class="section-title">Pro koho je čistička vzduchu bez filtrů ideální?</h2>
        <p class="section-subtitle">Přístroj je vhodný všude tam, kde záleží na kvalitě vzduchu a zdraví lidí.</p>
      </div>

      <div class="cards-grid cards-grid--5">
        <div class="card">
          <div class="card__icon">🏠</div>
          <h3>Domácnosti</h3>
          <p>Čistější vzduch v obýváku, ložnici i dětském pokoji. Konec se suchým vzduchem v zimě, prachem v paneláku nebo pachy z vaření. Jedno zařízení snadno přesunete díky kolečkům.</p>
        </div>
        <div class="card">
          <div class="card__icon">🏢</div>
          <h3>Kanceláře a firmy</h3>
          <p>Méně nemocných dní, vyšší produktivita. CDa Pro řeší syndrom nemocných budov v open space kancelářích — stačí ji pustit na 5 minut před začátkem pracovní doby.</p>
        </div>
        <div class="card">
          <div class="card__icon">🌿</div>
          <h3>Alergici a astmatici</h3>
          <p>Když vám běžná čistička s HEPA filtrem nestačí. CDa Pro zachycuje i ty nejjemnější alergeny — pyly, roztoče, spóry plísní — a navíc vzduch přirozeně zvlhčuje.</p>
        </div>
        <div class="card">
          <div class="card__icon">🏨</div>
          <h3>Hotely, restaurace, zdravotnictví</h3>
          <p>Profesionální řešení pro prostory, kde kvalita vzduchu přímo ovlivňuje spokojenost hostů nebo zdraví pacientů. Používá ji Nemocnice Strakonice — vítěz ocenění Nejlepší nemocnice 2024.</p>
        </div>
        <div class="card">
          <div class="card__icon">🏫</div>
          <h3>Školy a školky</h3>
          <p>Méně nemocných dětí, lepší soustředění, nižší absence. CDa Pro stačí pustit ráno na 5 minut před příchodem žáků — a třída je připravena na celý den.</p>
        </div>
      </div>

      <div class="product-showcase">
        <div class="product-showcase__image">
          <img src="/images/lifestyle-dog.jpg" alt="AirSancta CDa Pro v domácnosti se psem — bezpečná pro domácí zvířata" width="600" height="500" loading="lazy" />
        </div>
        <div class="product-showcase__content">
          <h3>Bezpečná za přítomnosti celé rodiny</h3>
          <p>CDa Pro nepoužívá žádné chemikálie — pouze čistou destilovanou vodu. Je proto naprosto bezpečná pro děti, seniory i domácí zvířata.</p>
          <p>Na rozdíl od UV dezinfekce nebo chemického mlžení může CDa Pro pracovat v místnosti s lidmi. Chemicky neutrální — jen voda.</p>
          <a href="#kontakt" class="btn btn-primary">Chci vyzkoušet jako první</a>
        </div>
      </div>
    </div>
  </section>

  <!-- VLASTNOSTI -->
  <section class="features" id="vlastnosti">
    <div class="container">
      <div class="features__inner">
        <div class="features__image">
          <img src="/images/product-cda-pro.jpg" alt="AirSancta CDa Pro — čistička vzduchu bez filtrů" width="500" height="600" loading="lazy" />
        </div>
        <div class="features__content">
          <span class="section-tag">Specifikace</span>
          <h2 class="section-title">Co dělá CDa Pro tak odlišnou od všeho, co znáte</h2>
          <ul class="features__list">
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Patentovaná NanoJet technologie — původně vyvinutá pro vojenskou obranu</strong>
                <span>Patent US 63/531 044, PCT/US24/25231</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
