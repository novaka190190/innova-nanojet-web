---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);

const categoryLabels: Record<string, string> = {
  technologie: 'Technologie',
  zdraví: 'Zdraví',
  tipy: 'Tipy',
  srovnání: 'Srovnání',
};
---

<BaseLayout
  title="Blog o kvalitě vzduchu | innova-nanojet.cz"
  description="Tipy, rady a informace o kvalitě vzduchu, čističkách vzduchu a zdravém domácím prostředí. Blog distributora AirSancta CDa Pro pro ČR a SR."
  canonical="https://innova-nanojet.cz/blog/"
>
  <header class="blog-index-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Domů</a>
        <span>›</span>
        <span>Blog</span>
      </nav>
      <h1>Blog o kvalitě vzduchu</h1>
      <p>Tipy, rady a informace pro zdravější domov a kancelář</p>
    </div>
  </header>

  <main class="blog-index-main">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post, index) => {
          const formattedDate = new Date(post.data.date).toLocaleDateString('cs-CZ', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a href={`/blog/${post.slug}/`} class={`post-card ${index === 0 ? 'post-card--featured' : ''}`}>
              {post.data.image && (
                <div class="post-card__image">
                  <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} width="600" height="340" loading="lazy" />
                </div>
              )}
              <div class="post-card__content">
                <div class="post-card__meta">
                  <span class={`blog-category blog-category--${post.data.category}`}>
                    {categoryLabels[post.data.category]}
                  </span>
                  <time datetime={post.data.date}>{formattedDate}</time>
                </div>
                <h2>{post.data.title}</h2>
                <p>{post.data.description}</p>
                <span class="post-card__link">Číst článek →</span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- CTA -->
      <div class="blog-bottom-cta">
        <h2>Buďte mezi prvními v ČR, kdo si tuto technologii vyzkouší</h2>
        <p>Inovativní produkt dostupný v ČR od roku 2025. Chcete být u toho? Napište nám — rádi odpovíme na vaše otázky a domluvíme předvedení přístroje.</p>
        <a href="/#kontakt" class="btn btn-primary">Kontaktujte nás</a>
      </div>
    </div>
  </main>

  <style>
    .blog-index-header {
      background: linear-gradient(135deg, var(--color-dark) 0%, var(--color-dark-mid) 100%);
      padding: 100px 0 60px;
      color: white;
    }
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
      margin-bottom: 24px;
    }
    .breadcrumb a { color: rgba(255,255,255,0.7); }
    .breadcrumb a:hover { color: white; }
    .blog-index-header h1 {
      font-size: clamp(2rem, 4vw, 3rem);
      margin-bottom: 12px;
    }
    .blog-index-header p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.7);
    }

    .blog-index-main {
      padding: 60px 0 80px;
    }

    .posts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      margin-bottom: 60px;
    }
    .post-card--featured {
      grid-column: span 3;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
    }
    .post-card {
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      overflow: hidden;
      display: block;
      transition: all 0.3s;
      background: white;
    }
    .post-card:hover {
      border-color: var(--color-blue);
      box-shadow: var(--shadow);
      transform: translateY(-4px);
    }
    .post-card__image img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      display: block;
    }
    .post-card--featured .post-card__image img {
      height: 100%;
      min-height: 320px;
    }
    .post-card__content {
      padding: 28px;
    }
    .post-card--featured .post-card__content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 40px;
    }
    .post-card__meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
    }
    .post-card__meta time {
      font-size: 0.8rem;
      color: var(--color-gray);
    }
    .post-card h2 {
      font-size: 1.1rem;
      color: var(--color-dark);
      margin-bottom: 10px;
      line-height: 1.3;
    }
    .post-card--featured h2 {
      font-size: 1.5rem;
    }
    .post-card p {
      font-size: 0.9rem;
      color: var(--color-gray);
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-card__link {
      display: inline-block;
      margin-top: 16px;
      color: var(--color-blue);
      font-size: 0.9rem;
      font-weight: 600;
    }

    .blog-category {
      display: inline-block;
      padding: 4px 14px;
      border-radius: 50px;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .blog-category--technologie { background: #dbeafe; color: #1d4ed8; }
    .blog-category--zdraví { background: #dcfce7; color: #166534; }
    .blog-category--tipy { background: #fef9c3; color: #854d0e; }
    .blog-category--srovnání { background: #f3e8ff; color: #7e22ce; }

    .blog-bottom-cta {
      background: var(--color-gray-light);
      border-radius: 24px;
      padding: 48px;
      text-align: center;
    }
    .blog-bottom-cta h2 {
      font-size: 1.8rem;
      color: var(--color-dark);
      margin-bottom: 12px;
    }
    .blog-bottom-cta p {
      color: var(--color-gray);
      margin-bottom: 28px;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }

    @media (max-width: 900px) {
      .posts-grid { grid-template-columns: repeat(2, 1fr); }
      .post-card--featured { grid-column: span 2; grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .posts-grid { grid-template-columns: 1fr; }
      .post-card--featured { grid-column: span 1; }
      .blog-bottom-cta { padding: 32px 24px; }
    }
  </style>
</BaseLayout>
