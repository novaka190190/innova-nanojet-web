---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://innova-nanojet.cz/#organization",
      "name": "Inovara Trade",
      "url": "https://innova-nanojet.cz",
      "email": "info@inovaratrade.com",
      "description": "Oficiální distributor AirSancta CDa Pro pro ČR a SR"
    },
    {
      "@type": "Product",
      "@id": "https://innova-nanojet.cz/#product",
      "name": "AirSancta CDa Pro",
      "description": "Revoluční čistička vzduchu bez filtrů s patentovanou NanoJet technologií. Používá pouze vodu k zachycení virů, bakterií, alergenů a prachu.",
      "brand": {
        "@type": "Brand",
        "name": "AirSancta"
      },
      "image": "https://innova-nanojet.cz/images/product-cda-pro.jpg",
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "priceCurrency": "CZK",
        "seller": {
          "@type": "Organization",
          "name": "Inovara Trade"
        }
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://innova-nanojet.cz/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Je CDa Pro čistička nebo zvlhčovač?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CDa Pro je primárně čistička vzduchu. Díky principu vodní mlhy ale přirozeně zvlhčuje vzduch, což je bonus zejména v zimě při vytápění."
          }
        },
        {
          "@type": "Question",
          "name": "Musím kupovat náhradní filtry?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ne. CDa Pro je kompletně bez filtrů. Používá pouze destilovanou vodu, což výrazně snižuje provozní náklady."
          }
        },
        {
          "@type": "Question",
          "name": "Jakou vodu mám používat?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pouze destilovanou nebo demineralizovanou vodu. Nepoužívejte kohoutkovou vodu — mohlo by dojít k ucpání trysek."
          }
        },
        {
          "@type": "Question",
          "name": "Je bezpečná pro děti a domácí zvířata?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ano. Přístroj nepoužívá žádné chemikálie — pouze čistou vodu. UV modul dezinfikuje vodu v nádrži před rozstřikem."
          }
        },
        {
          "@type": "Question",
          "name": "Jak hlučný je přístroj?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Hlučnost je přibližně 75–80 dB, podobně jako vysavač. Doporučujeme použít časovač a nechat přístroj pracovat v zavřené místnosti."
          }
        },
        {
          "@type": "Question",
          "name": "Může způsobit vlhkost nebo plísně?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Množství rozstřikované vody je minimální (35 ml/min). V místnostech bez existujících problémů s vlhkostí přístroj plísně nezpůsobuje."
          }
        },
        {
          "@type": "Question",
          "name": "Jak CDa Pro čistí vzduch od virů?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nano-kapky vody fyzicky obalí virové částice ve vzduchu, ztíží je a způsobí jejich pád. Tento princip byl ověřen nezávislými testy."
          }
        },
        {
          "@type": "Question",
          "name": "Kolik stojí provoz?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Provozní náklady jsou minimální — potřebujete pouze destilovanou vodu a elektřinu. Žádné filtry, žádné chemikálie."
          }
        }
      ]
    }
  ]
};
---

<BaseLayout
  title="AirSancta CDa Pro — Čistička vzduchu bez filtrů | innova-nanojet.cz"
  description="Čistý vzduch pro váš domov i kancelář. AirSancta CDa Pro — revoluční čistička vzduchu bez filtrů s NanoJet technologií. Odstraňuje 99 % virů, bakterií a alergenů. Distributor pro ČR a SR."
>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- NAVIGACE -->
  <nav class="nav">
    <div class="nav__inner container">
      <a href="/" class="nav__logo">
        <img src="/images/airsancta-logo.png" alt="AirSancta logo" width="140" height="40" />
      </a>
      <ul class="nav__links">
        <li><a href="#jak-to-funguje">Technologie</a></li>
        <li><a href="#pro-koho">Pro koho</a></li>
        <li><a href="#vlastnosti">Vlastnosti</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="#kontakt" class="btn btn-primary">Kontakt</a></li>
      </ul>
      <button class="nav__toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero__bg">
      <img src="/images/hero.jpg" alt="AirSancta CDa Pro čistička vzduchu v moderním interiéru" width="1920" height="1080" />
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__content container">
      <div class="hero__badge">
        <img src="/images/ces-award.png" alt="CES Innovation Award" width="80" height="80" />
        <span>Ocenění CES Innovation</span>
      </div>
      <h1 class="hero__title">Čistý vzduch pro váš<br />domov i kancelář</h1>
      <p class="hero__subtitle">
        AirSancta CDa Pro — revoluční čistička vzduchu bez filtrů.<br />
        Používá pouze vodu. Žádná chemie. Žádné filtry.
      </p>
      <div class="hero__actions">
        <a href="#kontakt" class="btn btn-primary">Chci více informací</a>
        <a href="#jak-to-funguje" class="btn btn-outline">Jak to funguje?</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <strong>99 %</strong>
          <span>odstranění znečišťujících látek</span>
        </div>
        <div class="hero__stat">
          <strong>120 m²</strong>
          <span>pokrytá plocha</span>
        </div>
        <div class="hero__stat">
          <strong>0 ks</strong>
          <span>náhradních filtrů</span>
        </div>
      </div>
    </div>
    <a href="#jak-to-funguje" class="hero__scroll" aria-label="Scrollovat dolů">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14M5 12l7 7 7-7"/>
      </svg>
    </a>
  </section>

  <!-- JAK TO FUNGUJE -->
  <section class="how-it-works" id="jak-to-funguje">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Technologie</span>
        <h2 class="section-title">Jak funguje technologie NanoJet?</h2>
        <p class="section-subtitle">
          Na rozdíl od klasických čističek s HEPA filtry používá CDa Pro pouze vodu.
          Žádné drahé výměny filtrů, žádné chemikálie.
        </p>
      </div>

      <div class="how-it-works__steps">
        <div class="step">
          <div class="step__icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="28" fill="rgba(33,150,243,0.12)"/>
              <path d="M32 20c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm0 4a8 8 0 110 16 8 8 0 010-16z" fill="#2196F3"/>
              <circle cx="20" cy="22" r="3" fill="#2196F3" opacity="0.6"/>
              <circle cx="44" cy="22" r="2" fill="#2196F3" opacity="0.4"/>
              <circle cx="44" cy="42" r="3" fill="#2196F3" opacity="0.6"/>
              <circle cx="20" cy="42" r="2" fill="#2196F3" opacity="0.4"/>
            </svg>
          </div>
          <div class="step__num">1</div>
          <h3>Biliony nano-kapek</h3>
          <p>Přístroj generuje biliony ultrarychlých nano-vodních kapek, které zaplní celou místnost.</p>
        </div>
        <div class="step__arrow">→</div>
        <div class="step">
          <div class="step__icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="28" fill="rgba(33,150,243,0.12)"/>
              <path d="M24 28l8 8 8-8" stroke="#2196F3" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M20 36s4-8 12-8 12 8 12 8" stroke="#2196F3" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="32" cy="20" r="4" fill="#2196F3"/>
            </svg>
          </div>
          <div class="step__num">2</div>
          <h3>Zachycení a eliminace</h3>
          <p>Kapky zachytí viry, bakterie, alergeny a prach ve vzduchu a obalí je ve vodě.</p>
        </div>
        <div class="step__arrow">→</div>
        <div class="step">
          <div class="step__icon">
            <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="32" cy="32" r="28" fill="rgba(33,150,243,0.12)"/>
              <path d="M32 18v28M22 36l10 10 10-10" stroke="#2196F3" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M20 22h24" stroke="#2196F3" stroke-width="2" stroke-linecap="round" opacity="0.5"/>
            </svg>
          </div>
          <div class="step__num">3</div>
          <h3>Čistý vzduch za minuty</h3>
          <p>Kontaminanty ztěžknou a klesnou — vzduch je čistý během minut. Přirozeně, bez chemie.</p>
        </div>
      </div>

      <div class="how-it-works__visual">
        <div class="how-it-works__image">
          <img src="/images/nanojet-diagram.png" alt="Diagram technologie NanoJet — jak nano-kapky čistí vzduch" width="600" height="400" />
        </div>
        <div class="how-it-works__text">
          <h3>Patentovaná fyzikální metoda</h3>
          <p>
            NanoJet technologie využívá čistě fyzikální princip bez jakýchkoli chemických přísad.
            Průmyslová tryska rozprašuje vodu na ultra-miniaturní kapky o velikosti 5–10 mikronů,
            které jsou 1000× menší než kapky z klasického zvlhčovače.
          </p>
          <p>
            Tyto kapky mají obrovský celkový povrch, díky čemuž jsou extrémně efektivní
            při zachycování aerosolových částic, virů a bakterií z okolního vzduchu.
          </p>
          <ul class="check-list">
            <li>Ověřeno nezávislými laboratořemi</li>
            <li>Ocenění CES Innovation Award</li>
            <li>Patentovaná technologie innova-nanojet</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PRO KOHO -->
  <section class="for-whom" id="pro-koho">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Využití</span>
        <h2 class="section-title">Pro koho je AirSancta CDa Pro</h2>
        <p class="section-subtitle">Přístroj je vhodný všude tam, kde záleží na kvalitě vzduchu a zdraví lidí.</p>
      </div>

      <div class="cards-grid">
        <div class="card">
          <div class="card__icon">🏠</div>
          <h3>Domácnosti</h3>
          <p>Zlepšete kvalitu vzduchu v obýváku, ložnici nebo dětském pokoji. Ideální pro rodiny s malými dětmi.</p>
        </div>
        <div class="card">
          <div class="card__icon">🏢</div>
          <h3>Kanceláře</h3>
          <p>Snižte šíření virů a zvyšte produktivitu zaměstnanců. Čistší vzduch = méně nemocných dní.</p>
        </div>
        <div class="card">
          <div class="card__icon">🌿</div>
          <h3>Alergici</h3>
          <p>Rychle odstraňte pyly, roztoče a další alergeny. Uleva od sezónních i celoročních alergií.</p>
        </div>
        <div class="card">
          <div class="card__icon">🏨</div>
          <h3>Hotely & restaurace</h3>
          <p>Profesionální čištění vzduchu pro vaše hosty. Eliminace pachů z kuchyně a cigaretového kouře.</p>
        </div>
      </div>

      <div class="product-showcase">
        <div class="product-showcase__image">
          <img src="/images/lifestyle-dog.jpg" alt="AirSancta CDa Pro v domácnosti se psem — bezpečná pro domácí zvířata" width="600" height="500" />
        </div>
        <div class="product-showcase__content">
          <h3>Bezpečná pro celou rodinu</h3>
          <p>CDa Pro nepoužívá žádné chemikálie — pouze čistou destilovanou vodu. Je proto naprosto bezpečná pro děti, seniory i domácí zvířata.</p>
          <p>UV modul navíc dezinfikuje vodu v nádrži ještě před rozstřikem, takže do vzduchu se dostává skutečně čistá voda.</p>
          <a href="#kontakt" class="btn btn-primary">Zjistit více</a>
        </div>
      </div>
    </div>
  </section>

  <!-- VLASTNOSTI -->
  <section class="features" id="vlastnosti">
    <div class="container">
      <div class="features__inner">
        <div class="features__image">
          <img src="/images/product-cda-pro.jpg" alt="AirSancta CDa Pro — detail produktu" width="500" height="600" />
        </div>
        <div class="features__content">
          <span class="section-tag">Specifikace</span>
          <h2 class="section-title">Co dělá CDa Pro výjimečnou</h2>
          <ul class="features__list">
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Patentovaná NanoJet technologie</strong>
                <span>Jedinečný fyzikální princip čištění vzduchu</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Bez filtrů — používá pouze vodu</strong>
                <span>Žádné drahé výměny filtrů každé 3 měsíce</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Odstranění 99 % znečišťujících látek</strong>
                <span>Viry, bakterie, plísně, alergeny, prach, VOC</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Bez chemikálií — čistě fyzikální princip</strong>
                <span>Bezpečné pro děti, seniory i domácí zvířata</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Nízká spotřeba energie</strong>
                <span>Efektivní provoz s minimálními náklady</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>UV dezinfekce vody v nádrži</strong>
                <span>Voda je dezinfikována UV světlem před každým rozstřikem</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Vhodná pro prostory do 120 m²</strong>
                <span>Pokryje obývací pokoj, kancelář i větší místnosti</span>
              </div>
            </li>
            <li>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="10" fill="#2196F3"/>
                <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <div>
                <strong>Provoz cca 45 minut na jednu nádrž (1,8 l)</strong>
                <span>Dostatečně dlouhé cykly pro efektivní čištění</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq" id="faq">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Otázky a odpovědi</span>
        <h2 class="section-title">Často kladené otázky</h2>
        <p class="section-subtitle">Máte otázku, kterou tu nenajdete? Neváhejte nás kontaktovat.</p>
      </div>

      <div class="faq__list">
        <details class="faq__item">
          <summary>Je CDa Pro čistička nebo zvlhčovač?</summary>
          <p>CDa Pro je primárně čistička vzduchu. Díky principu vodní mlhy ale přirozeně zvlhčuje vzduch, což je bonus zejména v zimě při vytápění.</p>
        </details>
        <details class="faq__item">
          <summary>Musím kupovat náhradní filtry?</summary>
          <p>Ne. CDa Pro je kompletně bez filtrů. Používá pouze destilovanou vodu, což výrazně snižuje provozní náklady.</p>
        </details>
        <details class="faq__item">
          <summary>Jakou vodu mám používat?</summary>
          <p>Pouze destilovanou nebo demineralizovanou vodu. Nepoužívejte kohoutkovou vodu — mohlo by dojít k ucpání trysek.</p>
        </details>
        <details class="faq__item">
          <summary>Je bezpečná pro děti a domácí zvířata?</summary>
          <p>Ano. Přístroj nepoužívá žádné chemikálie — pouze čistou vodu. UV modul dezinfikuje vodu v nádrži před rozstřikem.</p>
        </details>
        <details class="faq__item">
          <summary>Jak hlučný je přístroj?</summary>
          <p>Hlučnost je přibližně 75–80 dB, podobně jako vysavač. Doporučujeme použít časovač a nechat přístroj pracovat v zavřené místnosti.</p>
        </details>
        <details class="faq__item">
          <summary>Může způsobit vlhkost nebo plísně?</summary>
          <p>Množství rozstřikované vody je minimální (35 ml/min). V místnostech bez existujících problémů s vlhkostí přístroj plísně nezpůsobuje.</p>
        </details>
        <details class="faq__item">
          <summary>Jak CDa Pro čistí vzduch od virů?</summary>
          <p>Nano-kapky vody fyzicky obalí virové částice ve vzduchu, ztíží je a způsobí jejich pád. Tento princip byl ověřen nezávislými testy.</p>
        </details>
        <details class="faq__item">
          <summary>Kolik stojí provoz?</summary>
          <p>Provozní náklady jsou minimální — potřebujete pouze destilovanou vodu a elektřinu. Žádné filtry, žádné chemikálie.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- KONTAKT -->
  <section class="contact" id="kontakt">
    <div class="container">
      <div class="contact__inner">
        <div class="contact__info">
          <span class="section-tag">Kontakt</span>
          <h2 class="section-title" style="color:white;">Zajímá vás AirSancta CDa Pro?</h2>
          <p style="color:rgba(255,255,255,0.8); font-size:1.1rem; margin-bottom:32px;">
            Napište nám a rádi vám poskytneme více informací, domluvíme předvedení nebo probereme možnosti pořízení.
          </p>
          <div class="contact__direct">
            <p style="color:rgba(255,255,255,0.7);">Nebo nám napište přímo:</p>
            <a href="mailto:info@inovaratrade.com?subject=Zájem%20o%20AirSancta%20CDa%20Pro" class="contact__email">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              info@inovaratrade.com
            </a>
          </div>
          <img src="/images/cda-mini-lifestyle.jpg" alt="AirSancta CDa Pro v moderní kanceláři" width="400" height="280" class="contact__image" />
