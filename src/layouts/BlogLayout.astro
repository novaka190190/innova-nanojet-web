---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'blog'>;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { entry, relatedPosts = [] } = Astro.props;
const { title, description, date, category, image, imageAlt } = entry.data;
const siteUrl = 'https://innova-nanojet.cz';
const postUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image ? new URL(image, siteUrl).href : `${siteUrl}/images/product-cda-pro.jpg`;

const categoryLabels: Record<string, string> = {
  technologie: 'Technologie',
  zdraví: 'Zdraví',
  tipy: 'Tipy',
  srovnání: 'Srovnání',
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": ogImage,
  "datePublished": date,
  "author": {
    "@type": "Organization",
    "name": "Inovara Trade",
    "url": siteUrl,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Inovara Trade",
    "url": siteUrl,
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl,
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Domů", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${siteUrl}/blog/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": postUrl },
  ],
};

const formattedDate = new Date(date).toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${title} | Blog innova-nanojet.cz`}
  description={description}
  image={image}
  canonical={postUrl}
  type="article"
  articleDate={date}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <header class="blog-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Domů</a>
        <span>›</span>
        <a href="/blog/">Blog</a>
        <span>›</span>
        <span>{title}</span>
      </nav>
    </div>
  </header>

  <main class="blog-main">
    <article class="blog-article container">
      <header class="blog-article__header">
        <div class="blog-meta">
          <span class={`blog-category blog-category--${category}`}>{categoryLabels[category]}</span>
          <time datetime={date}>{formattedDate}</time>
        </div>
        <h1 class="blog-article__title">{title}</h1>
        <p class="blog-article__description">{description}</p>
      </header>

      {image && (
        <div class="blog-article__hero">
          <img src={image} alt={imageAlt ?? title} width="1200" height="600" loading="lazy" />
        </div>
      )}

      <div class="blog-article__body prose">
        <slot />
      </div>

      <!-- CTA Box -->
      <div class="blog-cta">
        <div class="blog-cta__icon">💨</div>
        <div>
          <h3>Zajímá vás čistý vzduch?</h3>
          <p>Vyzkoušejte AirSancta CDa Pro — čističku vzduchu bez filtrů pro váš domov nebo kancelář. Kontaktujte nás a rádi vám poradíme.</p>
        </div>
        <a href="/#kontakt" class="btn btn-primary">Kontaktujte nás</a>
      </div>

      <!-- Related posts -->
      {relatedPosts.length > 0 && (
        <section class="blog-related">
          <h2>Další články</h2>
          <div class="blog-related__grid">
            {relatedPosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="blog-related__card">
                {post.data.image && (
                  <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} width="400" height="220" loading="lazy" />
                )}
                <div class="blog-related__content">
                  <span class={`blog-category blog-category--${post.data.category}`}>{categoryLabels[post.data.category]}</span>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>
  </main>

  <footer class="blog-footer-nav">
    <div class="container">
      <a href="/blog/" class="btn btn-outline-dark">← Zpět na blog</a>
      <a href="/" class="btn btn-outline-dark">Domovská stránka</a>
    </div>
  </footer>

  <style>
    .blog-header {
      background: var(--color-dark);
      padding: 80px 0 24px;
    }
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
    }
    .breadcrumb a {
      color: rgba(255,255,255,0.7);
      transition: color 0.2s;
    }
    .breadcrumb a:hover { color: white; }

    .blog-main {
      padding: 40px 0 80px;
    }
    .blog-article {
      max-width: 800px;
    }
    .blog-article__header {
      margin-bottom: 32px;
    }
    .blog-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 20px;
    }
    .blog-category {
      display: inline-block;
      padding: 4px 14px;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .blog-category--technologie { background: #dbeafe; color: #1d4ed8; }
    .blog-category--zdraví { background: #dcfce7; color: #166534; }
    .blog-category--tipy { background: #fef9c3; color: #854d0e; }
    .blog-category--srovnání { background: #f3e8ff; color: #7e22ce; }
    .blog-meta time {
      font-size: 0.85rem;
      color: var(--color-gray);
    }
    .blog-article__title {
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--color-dark);
      margin-bottom: 16px;
    }
    .blog-article__description {
      font-size: 1.15rem;
      color: var(--color-gray);
      line-height: 1.7;
    }
    .blog-article__hero {
      margin-bottom: 40px;
      border-radius: var(--radius);
      overflow: hidden;
    }
    .blog-article__hero img {
      width: 100%;
      height: 400px;
      object-fit: cover;
    }
    .prose {
      font-size: 1.05rem;
      line-height: 1.8;
      color: var(--color-gray-dark);
    }
    .prose h2 {
      font-size: 1.6rem;
      color: var(--color-dark);
      margin: 48px 0 20px;
    }
    .prose h3 {
      font-size: 1.25rem;
      color: var(--color-dark);
      margin: 32px 0 14px;
    }
    .prose p { margin-bottom: 22px; }
    .prose ul, .prose ol {
      margin: 0 0 24px 28px;
    }
    .prose li { margin-bottom: 10px; line-height: 1.75; }
    .prose strong { color: var(--color-dark); font-weight: 600; }
    .prose blockquote {
      border-left: 4px solid var(--color-blue);
      padding: 16px 24px;
      margin: 28px 0;
      background: var(--color-gray-light);
      border-radius: 0 var(--radius) var(--radius) 0;
      font-style: italic;
    }
    .prose a { color: var(--color-blue); text-decoration: underline; }
    .prose img {
      border-radius: var(--radius);
      margin: 24px 0;
      max-width: 100%;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 28px 0;
      font-size: 0.92rem;
      overflow-x: auto;
      display: block;
    }
    .prose table th {
      background: var(--color-dark);
      color: white;
      padding: 12px 16px;
      text-align: left;
      font-weight: 600;
    }
    .prose table td {
      padding: 11px 16px;
      border-bottom: 1px solid #e5e7eb;
      color: var(--color-gray-dark);
    }
    .prose table tr:last-child td { border-bottom: none; }
    .prose table tr:nth-child(even) { background: #f9fafb; }
    .prose table tr:hover { background: #f0f9ff; }

    .blog-cta {
      display: flex;
      align-items: center;
      gap: 24px;
      background: linear-gradient(135deg, var(--color-dark) 0%, var(--color-dark-mid) 100%);
      border-radius: var(--radius);
      padding: 32px;
      margin: 48px 0;
      flex-wrap: wrap;
    }
    .blog-cta__icon { font-size: 3rem; flex-shrink: 0; }
    .blog-cta h3 { color: white; margin-bottom: 8px; }
    .blog-cta p { color: rgba(255,255,255,0.7); font-size: 0.9rem; }
    .blog-cta .btn { flex-shrink: 0; white-space: nowrap; }

    .blog-related { margin-top: 48px; }
    .blog-related h2 {
      font-size: 1.4rem;
      color: var(--color-dark);
      margin-bottom: 24px;
    }
    .blog-related__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .blog-related__card {
      border: 1px solid #e5e7eb;
      border-radius: var(--radius);
      overflow: hidden;
      display: block;
      transition: all 0.3s;
    }
    .blog-related__card:hover {
      border-color: var(--color-blue);
      box-shadow: var(--shadow);
      transform: translateY(-3px);
    }
    .blog-related__card img {
      width: 100%;
      height: 160px;
      object-fit: cover;
    }
    .blog-related__content {
      padding: 16px;
    }
    .blog-related__content h3 {
      font-size: 0.95rem;
      color: var(--color-dark);
      margin: 8px 0 6px;
      line-height: 1.3;
    }
    .blog-related__content p {
      font-size: 0.8rem;
      color: var(--color-gray);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .blog-footer-nav {
      background: var(--color-gray-light);
      padding: 32px 0;
    }
    .blog-footer-nav .container {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-outline-dark {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      border-radius: 50px;
      border: 1.5px solid var(--color-dark);
      color: var(--color-dark);
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.2s;
    }
    .btn-outline-dark:hover {
      background: var(--color-dark);
      color: white;
    }

    @media (max-width: 768px) {
      .blog-related__grid { grid-template-columns: 1fr; }
      .blog-cta { flex-direction: column; text-align: center; }
    }
  </style>
</BaseLayout>
